# ChessHeroQuest — environment variables (copy to .env.local)
# Secrets are SERVER-SIDE ONLY. Never expose anything but NEXT_PUBLIC_* to the client.

# --- Core (MVP) ---
DATABASE_URL=                      # Neon Postgres connection string
ANTHROPIC_API_KEY=                 # AI coach (server-side, cached)
AUTH_SECRET=                       # session/auth signing secret

# --- Billing (MVP) ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=   # client-side checkout token (safe to expose)
NEXT_PUBLIC_PADDLE_ENV=sandbox     # "sandbox" | "production"
# Paddle price IDs (public, per-account) — one per plan
NEXT_PUBLIC_PADDLE_PRICE_FREE=
NEXT_PUBLIC_PADDLE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_PADDLE_PRICE_PRO_ANNUAL=
NEXT_PUBLIC_PADDLE_PRICE_LIFETIME=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Monitoring (MVP-min) ---
SENTRY_DSN=

# --- Admin fortress (LAW #7) ---
# Comma-separated allowlist of admin emails (lowercase/trim compare). Admin =
# on this list OR users.role='admin' (migration 0011); everyone else gets a 404
# on /admin (the route stays invisible — never a 403). The allowlist is the
# BREAK-GLASS path: always active, works even before 0011 is applied, and ONLY
# allowlisted admins can grant/remove the DB admin role (anti-escalation).
# Example: ADMIN_EMAILS=alain@monkeoz.com,ops@chessheroquest.com
ADMIN_EMAILS=

# --- Chess data ---
# Lichess Opening Explorer API needs NO key (public). Respect rate limits + attribution.
# Stockfish runs locally (WASM). ECO files are bundled. No keys.

# --- Admin integrations (V1/V2 — leave blank until built) ---
CRISP_WEBSITE_ID=                  # support tickets
KLAVIYO_API_KEY=                   # email sequences
INSTANTLY_API_KEY=                 # email sequences
GSC_CLIENT_ID=                     # Google Search Console
GSC_CLIENT_SECRET=
GOOGLE_INDEXING_KEY=               # Google Indexing API (service account)
BING_INDEXNOW_KEY=                 # Bing IndexNow
