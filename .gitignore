# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Stockfish WASM — reproduced from node_modules by postinstall (7 MB, not committed)
/public/stockfish/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# corrupt .git backup (failing-disk objects) — do not track
.git-corrupt-bak/

.DS_Store
